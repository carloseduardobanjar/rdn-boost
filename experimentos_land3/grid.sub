executable = /home/users/cschuller/rdn-boost/experimentos_land3/run.sh
initialdir = /home/users/cschuller/rdn-boost/experimentos_land3

# Use caminhos relativos ao initialdir para facilitar
output = logs/job_$(depth)_$(size)_$(est).out
error  = logs/job_$(depth)_$(size)_$(est).err
log    = logs/job_$(depth)_$(size)_$(est).log

arguments = --max_depth $(depth) --node_size $(size) --n_estimators $(est) --data_path /home/users/cschuller/rdn-boost/experimentos_land3/dataset --output_path /home/users/cschuller/rdn-boost/experimentos_land3/output/res_d$(depth)_s$(size)_e$(est)

should_transfer_files = YES
when_to_transfer_output = ON_EXIT
transfer_output_files = results_$(depth)_$(size)_$(est)

request_cpus = 1
request_memory = 2048

queue depth, size, est from (
    3, 2, 50
)